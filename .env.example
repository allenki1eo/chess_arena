# ─── OpenRouter (AI villain speech) ──────────────────────────────────────────
# Get your free key at https://openrouter.ai/keys
# Free models work without a key — fallback lines are used instead
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ─── Supabase (global leaderboard) ───────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
# The game works fine without these — scores save locally only
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ─── Vite exposes these to the frontend (public values only) ─────────────────
# These are SAFE to expose — they're the anon/public keys
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
